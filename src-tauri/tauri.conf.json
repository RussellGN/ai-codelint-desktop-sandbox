{
   "$schema": "https://schema.tauri.app/config/2",
   "productName": "ai-codelint-desktop-sandbox",
   "version": "0.0.1",
   "identifier": "com.gundani.ai-codelint-desktop-sandbox",
   "build": {
      "beforeDevCommand": "pnpm dev",
      "devUrl": "http://localhost:1420",
      "beforeBuildCommand": "pnpm build",
      "frontendDist": "../dist"
   },
   "app": {
      "windows": [
         {
            "title": "ai-codelint-desktop-sandbox",
            "width": 1200,
            "height": 800,
            "maximized": true
         }
      ],
      "security": {
         "csp": null
      }
   },
   "bundle": {
      "active": true,
      "targets": "all",
      "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
   }
}
